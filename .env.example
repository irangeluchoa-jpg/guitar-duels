# Encontre esses valores em: https://supabase.com/dashboard
# → Selecione seu projeto → Project Settings → API
#
# 1. "Project URL" → cole aqui:
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# 2. "anon / public key" → cole aqui:
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ════════════════════════════════════════════════════════
#  URL pública do seu deploy (necessário para a API de músicas funcionar na Vercel)
#  Exemplo: https://guitar-duel-fixed.vercel.app
# ════════════════════════════════════════════════════════
NEXT_PUBLIC_SITE_URL=https://SEU-DOMINIO.vercel.app
